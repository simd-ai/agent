# ══════════════════════════════════════════════════════════════
# SIMD Agent — Environment Configuration
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in the required values.
#
# Required vars are marked with [REQUIRED].
# Everything else has sensible defaults for local development.
# ══════════════════════════════════════════════════════════════

# ── Database [REQUIRED] ──────────────────────────────────────
# Docker: use the internal postgres service name
# Bare metal: point to your own Postgres instance
DATABASE_URL=postgresql://simd:simd@postgres:5432/simd

# ── LLM Provider [REQUIRED] ─────────────────────────────────
# At minimum you need a Gemini API key.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Provider selection (default: gemini)
# DEFAULT_PROVIDER=gemini
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_SUPER_MODEL=gemini-3.1-pro-preview

# ── Simulation Server ────────────────────────────────────────
# URL of the OpenFOAM runner service.
# Docker: use the internal service name
# Bare metal: point to your own OpenFOAM runner
SIMULATION_SERVER_URL=http://runner:9000

# ── Object Storage ───────────────────────────────────────────
# Meshes, VTP results, and case ZIPs are stored here.
#
# Option 1: Local filesystem (default — no setup needed)
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/app/storage

# Option 2: Google Cloud Storage
# STORAGE_BACKEND=gcs
# STORAGE_BUCKET=your-bucket-name
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-key.json

# ── Progress Data ────────────────────────────────────────────
# Convergence residuals stored as compressed NDJSON.
# Buffered locally during runs, optionally uploaded to GCS.
PROGRESS_DATA_DIR=/tmp/simd_progress
# PROGRESS_GCS_BUCKET=your-progress-bucket

# ── Authentication ───────────────────────────────────────────
# Default: disabled — single local user, no signup required.
# To enable Neon Auth, set the base URL:
# NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech

# ── Frontend ─────────────────────────────────────────────────
# These are used by the frontend container (agent-frontend/ui).
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AUTH_DISABLED=true
# NEXT_PUBLIC_DEV_USER_EMAIL=local@simd.local

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Self-Healing ─────────────────────────────────────────────
MAX_RETRIES=3

# ── Usage Limits ─────────────────────────────────────────────
# Free tier: 3 active projects, 5 simulation runs.
# Local/self-hosted mode (no NEON_AUTH_BASE_URL): unlimited.
# Pro tier (Stripe subscription active): unlimited.
