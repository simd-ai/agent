FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0/innerFluid";
    object      cellToRegion;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    back
    {
        type            empty;
    }
    innerFluid_symmetry
    {
        type            symmetry;
    }
    innerFluid_outlet
    {
        type            zeroGradient;
    }
    innerFluid_inlet
    {
        type            zeroGradient;
    }
    front
    {
        type            empty;
    }
    innerFluid_to_wall
    {
        type            calculated;
        value           uniform 0;
    }
}


