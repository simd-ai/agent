FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       polyBoundaryMesh;
    location    "constant/wall/polyMesh";
    object      boundary;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

6
(
    back
    {
        type            empty;
        inGroups        1(empty);
        nFaces          6000;
        startFace       10994;
    }
    front
    {
        type            empty;
        inGroups        1(empty);
        nFaces          6000;
        startFace       16994;
    }
    wall_right_end
    {
        type            wall;
        inGroups        1(wall);
        nFaces          6;
        startFace       22994;
    }
    wall_left_end
    {
        type            wall;
        inGroups        1(wall);
        nFaces          6;
        startFace       23000;
    }
    wall_to_innerFluid
    {
        type            mappedWall;
        inGroups        1(wall);
        nFaces          1000;
        startFace       23006;
        sampleMode      nearestPatchFace;
        sampleRegion    innerFluid;
        samplePatch     innerFluid_to_wall;
    }
    wall_to_outerFluid
    {
        type            mappedWall;
        inGroups        1(wall);
        nFaces          1000;
        startFace       24006;
        sampleMode      nearestPatchFace;
        sampleRegion    outerFluid;
        samplePatch     outerFluid_to_wall;
    }
)

