FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant/wall";
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIso;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        nMoles      1;
        molWeight   50;
    }
    transport
    {
        kappa       16.2;
    }
    thermodynamics
    {
        Hf          0;
        Cp          500;
    }
    equationOfState
    {
        rho         7900;
    }
}

