FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        smoother        GaussSeidel;
        nCoarsestCells  20;
        tolerance       1e-06;
        relTol          0.1;
        coarsestLevelCorr
        {
            solver          PCG;
            preconditioner  DIC;
            tolerance       1e-09;
            relTol          0;
        }
    }

    rho
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-06;
        relTol          0;
    }

    "(U|k|omega)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-05;
        relTol          0.1;
    }

    e
    {
        solver          PBiCG;
        preconditioner  DILU;
        tolerance       1e-06;
        relTol          0.1;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 1;
    rhoMin          0.63;
    rhoMax          10;
    pMin            5066.25;
    pMax            2.0265e+06;
    pRefCell        0;
    pRefValue       0;

    residualControl
    {
        p               1e-3;
        U               1e-4;
        "(k|omega)"     1e-3;
        e               1e-3;
    }
}

relaxationFactors
{
    fields
    {
        p               0.3;
        rho             0.05;
    }
    equations
    {
        U               0.7;
        k               0.7;
        omega           0.7;
        e               0.5;
    }
}

