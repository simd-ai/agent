FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 1 0 0 0];

internalField   uniform 500.0;

boundaryField
{
    inlet_main
    {
        type            fixedValue;
        value           uniform 500.0;
    }
    inlet_small
    {
        type            fixedValue;
        value           uniform 280.0;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }
    walls
    {
        type            fixedValue;
        value           uniform 600.0;
    }
    back
    {
        type            empty;
    }
    front
    {
        type            empty;
    }
}

