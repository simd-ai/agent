FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 10;

boundaryField
{
    inlet_main
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    0.0100;
        value           uniform 10;
    }
    inlet_small
    {
        type            turbulentMixingLengthFrequencyInlet;
        mixingLength    0.0100;
        value           uniform 10;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }
    walls
    {
        type            omegaWallFunction;
        value           uniform 10;
    }
    back
    {
        type            empty;
    }
    front
    {
        type            empty;
    }
}

// ************************************************************************* //