FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    inlet_main
    {
        type            flowRateInletVelocity;
        massFlowRate    constant 0.012;
        value           uniform (0 0 0);
    }
    inlet_small
    {
        type            flowRateInletVelocity;
        massFlowRate    constant 0.001;
        value           uniform (0 0 0);
    }
    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }
    walls
    {
        type            noSlip;
    }
    back
    {
        type            empty;
    }
    front
    {
        type            empty;
    }
}

// ************************************************************************* //