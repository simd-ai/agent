FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];

internalField   uniform 0.0002;

boundaryField
{
    inlet_main
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.0500;
        value           uniform 0.0002;
    }
    inlet_small
    {
        type            turbulentIntensityKineticEnergyInlet;
        intensity       0.0500;
        value           uniform 0.0002;
    }
    outlet
    {
        type            inletOutlet;
        inletValue      $internalField;
        value           $internalField;
    }
    walls
    {
        type            kqRWallFunction;
        value           uniform 0.0002;
    }
    back
    {
        type            empty;
    }
    front
    {
        type            empty;
    }
}

// ************************************************************************* //